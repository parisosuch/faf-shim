# Admin credentials
# Set ADMIN_PASSWORD to your desired password — it is hashed in memory at startup.
# If not set, a random password is generated and logged to stdout on first boot.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Generate a JWT secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a random secret is generated each startup (sessions won't survive restarts).
JWT_SECRET=
JWT_EXPIRE_MINUTES=60
